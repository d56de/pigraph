# Pi-hole v6 Basis-URL (ohne /admin, ohne Slash am Ende)
PIHOLE_URL=http://pi.hole
# App-Passwort: Pi-hole Webinterface -> Settings -> Web Interface / API -> Configure app password
PIHOLE_PASSWORD=changeme
# Optional:
# POLL_INTERVAL_MS=2000
# PORT=5641
# Lokales DNS-Suffix, das von Client-Namen abgeschnitten wird (z.B. "iPhone.fritz.box" -> "iPhone").
# Standard: fritz.box. Leer setzen, um nichts abzuschneiden.
# CLIENT_NAME_SUFFIX=fritz.box
# Dashboard-Login (optional): leer lassen = kein Schutz (offen).
# DASHBOARD_PASSWORD=einGutesPasswort
# Stabiles Secret zum Signieren der Session — sonst Re-Login nach jedem Neustart.
# Erzeugen z.B. mit:  openssl rand -hex 32
# SESSION_SECRET=...
# Hinweis: Das Session-Cookie wird ohne Secure-Flag gesetzt (LAN/HTTP). Hinter einem
# TLS-Reverse-Proxy sollte secure: true im Cookie (app.ts) gesetzt werden.
# Gast-Modus (optional, nur mit DASHBOARD_PASSWORD): passwortloser, anonymisierter
# Read-Only-Blick (Clients/Domains pseudonymisiert, kein Feed/Panel).
# GUEST_MODE=true
